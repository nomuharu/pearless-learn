# データファイル (OHLCV CSV・npy ファイル) — ファイルは無視、ディレクトリ構造(.gitkeep)は追跡
data/raw/*
data/processed/*
data/npy/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/npy/.gitkeep
!data/npy/dataset-metadata.json
# pearless-src dataset用ディレクトリ — models/とinference/のコピーは無視
data/src/*
!data/src/dataset-metadata.json
# Windows ADS (Zone.Identifier)
*:Zone.Identifier

# 学習ログ CSV
logs/

# Kaggle API トークン / 環境変数ファイル
.env

# モデルファイル
*.pkl
*.pt

# Python キャッシュ
__pycache__/
*.pyc
*.pyo

# カバレッジ
.coverage

# 仮想環境
.venv/

# uv.lock はチーム開発では含める、個人開発では除外可
# uv.lock
