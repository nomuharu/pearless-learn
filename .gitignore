# データファイル (OHLCV CSV・npy ファイル) — ファイルは無視、ディレクトリ構造(.gitkeep)は追跡
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/npy/*
!data/npy/.gitkeep
!data/npy/dataset-metadata.json
data/npy_mtf/*
!data/npy_mtf/.gitkeep
!data/npy_mtf/dataset-metadata.json
# pearless-src dataset用ディレクトリ — models/とinference/のコピーは無視
data/src/*
!data/src/dataset-metadata.json
# Windows ADS (Zone.Identifier)
*:Zone.Identifier

# 学習ログ CSV
logs/

# Kaggle API トークン / 環境変数ファイル
.env

# モデルファイル
*.pkl
*.pt

# Python キャッシュ
__pycache__/
*.pyc
*.pyo

# カバレッジ
.coverage

# 仮想環境
.venv/

# uv.lock はチーム開発では含める、個人開発では除外可
# uv.lock
# 補助ラベル（pearless-aux-labels dataset用） — ファイルは無視、metadataは追跡
data/labels/*
!data/labels/dataset-metadata.json
# 採用済みモデルの重みは追跡する（グローバル *.pt 除外の例外）
!production/strategies/*/checkpoints/*.pt
# setuptools ビルドアーティファクト
*.egg-info/
